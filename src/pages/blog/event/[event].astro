---
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'

import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = true

export async function getStaticPaths() {
  const eventToSlug = (eventName: string) =>
    eventName
      .trim()
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')

  const collections = (await getCollection('blog')).sort(
    (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
  )

  const groupedByEvent = new Map<string, { name: string; posts: CollectionEntry<'blog'>[] }>()

  for (const post of collections) {
    const eventName = post.data.event?.trim()
    if (!eventName) continue

    const eventSlug = eventToSlug(eventName)
    if (!groupedByEvent.has(eventSlug)) {
      groupedByEvent.set(eventSlug, {
        name: eventName,
        posts: []
      })
    }

    groupedByEvent.get(eventSlug)?.posts.push(post)
  }

  return Array.from(groupedByEvent.entries()).map(([event, value]) => ({
    params: { event },
    props: {
      eventName: value.name,
      posts: value.posts
    }
  }))
}

interface Props {
  eventName: string
  posts: CollectionEntry<'blog'>[]
}

const { eventName, posts } = Astro.props

const meta = {
  description: `Challenge writeups for ${eventName}`,
  title: eventName
}
---

<PageLayout {meta}>
  <Button title='Back' href='/blog' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 mt-6 text-3xl font-medium sm:mt-10'>{eventName}</h1>
      <p class='text-muted-foreground mb-6 text-sm'>List challenge writeups for this event.</p>
    </div>

    {
      posts.length === 0 ? (
        <p>No challenge writeup yet for this event.</p>
      ) : (
        <section aria-label='Event challenge writeups list' class='animate' id='content'>
          <ul class='flex flex-col gap-y-3 text-start'>
            {posts.map((post) => (
              <li>
                <a
                  class='block rounded-xl border border-border bg-muted/30 px-4 py-3 transition hover:border-primary'
                  href={`/blog/${post.id}`}
                >
                  <p class='font-medium'>{post.data.title}</p>
                  {post.data.category && <p class='text-muted-foreground mt-1 text-sm'>{post.data.category}</p>}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </main>
</PageLayout>
